<Window x:Class="PresentationView.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Height="800" Width="1200"
        DataContext="{Binding MainViewModel, Source={StaticResource Locator}}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <Button Width="100" Height="30" Margin="0,0,15,0"
                    Content="Create Balls" 
                    Command="{Binding CreateBallsCommand}"/>

            <TextBlock Text="Amount:" VerticalAlignment="Center" Margin="0,0,5,0" />

            <Slider x:Name="BallsSlider" Width="150"
                    Minimum="1" Maximum="20" Value="{Binding SelectedBallCount}" VerticalAlignment="Center"
                    IsSnapToTickEnabled="True" TickFrequency="1" Margin="0,0,10,0" />

            <TextBlock Text="{Binding Value, ElementName=BallsSlider}" 
                       VerticalAlignment="Center" Width="20" />

            <TextBlock Text="Ball radius:" VerticalAlignment="Center" Margin="0,0,5,0" />

            <Slider x:Name="BallSize" Width="150"
            Minimum="1" Maximum="20" Value="{Binding SelectedBallRadius}" VerticalAlignment="Center"
            IsSnapToTickEnabled="True" TickFrequency="1" Margin="0,0,10,0" />

            <TextBlock Text="{Binding Value, ElementName=BallSize}" 
           VerticalAlignment="Center" Width="20" />
        </StackPanel>

        <Border Grid.Row="1" Width="900" Height="600" 
        BorderBrush="Black" BorderThickness="2" 
        HorizontalAlignment="Center" VerticalAlignment="Center">

            <ItemsControl Grid.Row="1" ItemsSource="{Binding Balls}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="WhiteSmoke" ClipToBounds="True"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Ellipse Fill="Blue" Width="{Binding D}" Height="{Binding D}">
                            <Ellipse.RenderTransform>
                                <TranslateTransform X="{Binding X}" Y="{Binding Y}"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </Border>
    </Grid>
</Window>